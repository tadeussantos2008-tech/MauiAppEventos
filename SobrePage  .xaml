<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="MauiAppEventos.Views.SobrePage"
             Title="Sobre"
             BackgroundColor="#F4F6FF">

    <ScrollView>
        <VerticalStackLayout Padding="20" Spacing="14">

            <!-- Header -->
            <Border BackgroundColor="#2C3E8C" Padding="20,18">
                <Border.StrokeShape><RoundRectangle CornerRadius="14"/></Border.StrokeShape>
                <VerticalStackLayout Spacing="6" HorizontalOptions="Center">
                    <Label Text="🎯" FontSize="48" HorizontalOptions="Center"/>
                    <Label Text="App Eventos"
                           FontSize="22" FontAttributes="Bold"
                           TextColor="White" HorizontalOptions="Center"/>
                    <Label Text="v1.0 — Agenda 15"
                           FontSize="12" TextColor="#A8B8F0" HorizontalOptions="Center"/>
                </VerticalStackLayout>
            </Border>

            <!-- Sobre o app -->
            <Border BackgroundColor="White" Stroke="#D0D8F5" StrokeThickness="1" Padding="16">
                <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Label Text="📱 Sobre o Aplicativo"
                           FontSize="15" FontAttributes="Bold" TextColor="#2C3E8C"/>
                    <BoxView HeightRequest="1" Color="#E8EDFB"/>
                    <Label TextColor="#555" FontSize="13" LineHeight="1.5">
                        <Label.Text>
Aplicativo de Cadastro de Eventos desenvolvido como atividade prática da Agenda 15 — Mostrando Dados Dinâmicos com BindingContext.

O app aplica os conceitos de BindingContext, StringFormat, DateTime e TimeSpan para exibir dados formatados entre telas.
                        </Label.Text>
                    </Label>
                </VerticalStackLayout>
            </Border>

            <!-- Desenvolvedor -->
            <Border BackgroundColor="White" Stroke="#D0D8F5" StrokeThickness="1" Padding="16">
                <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Label Text="👨‍💻 Desenvolvedor"
                           FontSize="15" FontAttributes="Bold" TextColor="#2C3E8C"/>
                    <BoxView HeightRequest="1" Color="#E8EDFB"/>
                    <Label Text="👤  Tadeu Souza Santos"          FontSize="13" TextColor="#333"/>
                    <Label Text="🎓  Técnico em Dev. de Sistemas" FontSize="13" TextColor="#333"/>
                    <Label Text="🏫  Centro Paula Souza — ETEC"   FontSize="13" TextColor="#333"/>
                    <Label Text="📅  Ano: 2026"                   FontSize="13" TextColor="#333"/>
                    <Label Text="📘  Programação Mobile I"        FontSize="13" TextColor="#333"/>
                </VerticalStackLayout>
            </Border>

            <!-- Conceitos aplicados -->
            <Border BackgroundColor="White" Stroke="#D0D8F5" StrokeThickness="1" Padding="16">
                <Border.StrokeShape><RoundRectangle CornerRadius="12"/></Border.StrokeShape>
                <VerticalStackLayout Spacing="10">
                    <Label Text="📚 Conceitos — Agenda 15"
                           FontSize="15" FontAttributes="Bold" TextColor="#2C3E8C"/>
                    <BoxView HeightRequest="1" Color="#E8EDFB"/>
                    <Label Text="✅  BindingContext entre páginas"   FontSize="13" TextColor="#333"/>
                    <Label Text="✅  StringFormat no XAML"           FontSize="13" TextColor="#333"/>
                    <Label Text="✅  DateTime e TimeSpan"            FontSize="13" TextColor="#333"/>
                    <Label Text="✅  Métodos async / await"          FontSize="13" TextColor="#333"/>
                    <Label Text="✅  Model classe Evento"            FontSize="13" TextColor="#333"/>
                    <Label Text="✅  Propriedades calculadas"        FontSize="13" TextColor="#333"/>
                </VerticalStackLayout>
            </Border>

            <!-- Tecnologias -->
            <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto"
                  ColumnSpacing="10" RowSpacing="10">
                <Border Grid.Row="0" Grid.Column="0" BackgroundColor="#EEF1FD" Stroke="#D0D8F5" Padding="12">
                    <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                    <VerticalStackLayout>
                        <Label Text=".NET MAUI" FontAttributes="Bold" TextColor="#2C3E8C" FontSize="13"/>
                        <Label Text="Framework" TextColor="#666" FontSize="11"/>
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Row="0" Grid.Column="1" BackgroundColor="#E8F5E9" Stroke="#C8E6C9" Padding="12">
                    <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                    <VerticalStackLayout>
                        <Label Text="C# 12" FontAttributes="Bold" TextColor="#2E7D32" FontSize="13"/>
                        <Label Text="Linguagem" TextColor="#666" FontSize="11"/>
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Row="1" Grid.Column="0" BackgroundColor="#FCE4EC" Stroke="#F8BBD0" Padding="12">
                    <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                    <VerticalStackLayout>
                        <Label Text="XAML" FontAttributes="Bold" TextColor="#C62828" FontSize="13"/>
                        <Label Text="Interface" TextColor="#666" FontSize="11"/>
                    </VerticalStackLayout>
                </Border>
                <Border Grid.Row="1" Grid.Column="1" BackgroundColor="#F3E5F5" Stroke="#E1BEE7" Padding="12">
                    <Border.StrokeShape><RoundRectangle CornerRadius="10"/></Border.StrokeShape>
                    <VerticalStackLayout>
                        <Label Text=".NET 8.0" FontAttributes="Bold" TextColor="#6A1B9A" FontSize="13"/>
                        <Label Text="Plataforma" TextColor="#666" FontSize="11"/>
                    </VerticalStackLayout>
                </Border>
            </Grid>

            <Button Text="Voltar"
                    Clicked="Button_Voltar_Clicked"
                    BackgroundColor="Transparent"
                    TextColor="#2C3E8C"
                    BorderColor="#2C3E8C"
                    BorderWidth="1"
                    CornerRadius="10"
                    Margin="0,6,0,20"/>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
